"""Test Optimized Job APIs - Now only 3 APIs"""
import os
import sys
import django
from pathlib import Path

BASE_DIR = Path(__file__).resolve().parent
sys.path.insert(0, str(BASE_DIR))
os.environ.setdefault('DJANGO_SETTINGS_MODULE', 'placement_partner.settings')
django.setup()

from core.job_search import fetch_jobs_for_skills

print('=' * 70)
print('TESTING OPTIMIZED JOB API SYSTEM (3 APIs Only)')
print('=' * 70)
print('\n🔍 Searching for Python Django jobs in India...\n')

jobs = fetch_jobs_for_skills(['python', 'django', 'react'], location='in', max_results=10)

if jobs:
    print(f'✅ SUCCESS! Found {len(jobs)} jobs\n')
    print('-' * 70)
    
    # Group by source
    by_source = {}
    for job in jobs:
        source = job.get("source", "Unknown")
        by_source[source] = by_source.get(source, 0) + 1
    
    print('\n📊 JOBS BY SOURCE:')
    print('-' * 70)
    for source, count in by_source.items():
        print(f'  ✅ {source}: {count} jobs')
    
    print('\n' + '-' * 70)
    print('📝 SAMPLE JOBS:')
    print('-' * 70)
    
    for i, job in enumerate(jobs[:5], 1):
        print(f'\n{i}. {job.get("title", "N/A")}')
        print(f'   Company: {job.get("company", "N/A")}')
        print(f'   Location: {job.get("location", "N/A")}')
        print(f'   Source: {job.get("source", "N/A")}')
        if job.get("salary_min") and job.get("salary_max"):
            print(f'   Salary: ₹{job.get("salary_min"):,} - ₹{job.get("salary_max"):,}')
        print(f'   URL: {job.get("url", "N/A")[:60]}...')
else:
    print('⚠️  No jobs found')

print('\n' + '=' * 70)
print('🎯 ACTIVE APIs (Optimized):')
print('  ✅ Remotive API (FREE, no key)')
print('  ✅ Arbeitnow API (FREE, no key)')
print('  ⚠️  Adzuna API (Optional - needs key for India jobs)')
print('\n❌ REMOVED: Jooble, JSearch, The Muse (unused/unreliable)')
print('=' * 70)
